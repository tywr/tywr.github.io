{{- $index := slice -}}
{{- range site.RegularPages -}}
  {{- $index = $index | append (dict
    "title"     .Title
    "permalink" .Permalink
    "summary"   .Summary
    "content"   (.Plain | truncate 500)
    "tags"      .Params.tags
    "date"      (.Date.Format "January 2, 2006")
  ) -}}
{{- end -}}
{{- $index | jsonify -}}
